rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cada usuario solo puede leer/escribir sus propios datos.
    // Solo las cuentas de Google autorizadas pueden usar la app.
    // Cada persona accede únicamente a sus propios datos (uid == userId).
    // Para autorizar a alguien más, agrega su email a esta lista y redespliega.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email in [
             'ignacublea@gmail.com',
             'lermandaguadalupe@gmail.com'
           ];
    }
  }
}
