rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cada usuario solo puede leer/escribir sus propios datos.
    // ADEMÁS se restringe el acceso únicamente a tu cuenta de Google:
    // ⚠️ IMPORTANTE: reemplaza el email de abajo por el tuyo ANTES de desplegar
    // (firebase deploy --only firestore:rules). Si despliegas con el placeholder,
    // nadie (ni tú) podrá leer/escribir datos.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email == 'TU_EMAIL_AQUI@gmail.com';
    }
  }
}
